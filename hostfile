# MPI hostfile — 4-node cluster (matches the master/slaveN naming from the
# cluster setup instruction: SSH keys id_rsa_master, id_rsa_slave1, ...).
#
# `slots` MUST equal the physical core count of each machine.
# Run `nproc` on every node and put the number here.
#
# These names must resolve — make sure /etc/hosts on every node maps
# master / slave1 / slave2 / slave3 to their IPs (VLAN or LAN).
#
# Example below assumes 4 cores per machine — CHANGE to your real core counts:
master slots=20
slave1 slots=8
slave2 slots=16
slave3 slots=16

# --- For local testing on this one 20-core machine instead, comment out the
#     four lines above and uncomment this:
# localhost slots=20
