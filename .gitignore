# ───────────────────────────────────────────────────────────────
# Build artifacts
# ───────────────────────────────────────────────────────────────
# Object files
*.o
*.obj
src/*.o

# Compiled binaries (no extension — must be named explicitly)
hybrid_attention
mpi-prime

# Other compiled outputs
*.out
*.exe
*.so
*.a
*.dwo
*.gch
*.pch

# ───────────────────────────────────────────────────────────────
# Benchmark output
# ───────────────────────────────────────────────────────────────
# Scratch / temp files written by the bench scripts (always throwaway)
results/.speedup_tmp.csv
results/*_tmp.csv
results/.*tmp*

# Auto-generated result CSVs (regenerable; commit the FINAL ones you want
# for the report with:  git add -f results/<file>.csv)
results/*.csv

# Keep the results/ directory itself in the repo
!results/.gitkeep

# ───────────────────────────────────────────────────────────────
# Editor / OS noise
# ───────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ───────────────────────────────────────────────────────────────
# Internal working docs (PRD / plan / agent state) — not part of the deliverable
# ───────────────────────────────────────────────────────────────
.claude/

# ───────────────────────────────────────────────────────────────
# Misc
# ───────────────────────────────────────────────────────────────
*.log
*.tmp
*.bak

# NOTE: do NOT ignore Makefile, hostfile, scripts/, src/, or *.md —
# those are all part of the project and must be committed.
